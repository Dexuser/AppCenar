<div class="container-fluid mt-2">
  <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div>
      <a href="/client/addresses" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
      </a>
      <h2 class="fw-bold mb-0 text-dark d-inline-block ms-3">Editar dirección</h2>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded p-3">
    <form method="POST" action="/client/addresses/{{address._id}}/edit">
      <div class="mb-3">
        <label class="form-label">Nombre de la dirección (ej: Casa, Trabajo)</label>
        <input type="text" name="label" class="form-control" value="{{address.label}}" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Calle</label>
        <input type="text" name="street" class="form-control" value="{{address.street}}" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Sector</label>
        <input type="text" name="sector" class="form-control" value="{{address.sector}}" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Ciudad</label>
        <input type="text" name="city" class="form-control" value="{{address.city}}" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Referencia / Descripción adicional</label>
        <textarea name="reference" class="form-control" rows="3" required>{{address.reference}}</textarea>
      </div>

      <div class="d-flex gap-2">
        <a href="/client/addresses" class="btn btn-outline-secondary w-50">Cancelar</a>
        <button type="submit" class="btn btn-primary w-50">
          <i class="bi bi-save2 me-1"></i> Guardar
        </button>
      </div>
    </form>
  </div>
</div>
