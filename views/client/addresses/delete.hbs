<div class="container-fluid mt-2">
  <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div>
      <a href="/client/addresses" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
      </a>
      <h2 class="fw-bold mb-0 text-dark d-inline-block ms-3">Eliminar dirección</h2>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded p-4 text-center">
    <div class="display-6 text-danger mb-2">
      <i class="bi bi-exclamation-triangle"></i>
    </div>
    <h4 class="mb-3">¿Está seguro que desea eliminar esta dirección?</h4>
    <div class="text-muted mb-4">
      <div class="fw-bold">{{address.title}}</div>
      <div>{{address.description}}</div>
    </div>

    <div class="d-flex gap-2 justify-content-center">
      <a href="/client/addresses" class="btn btn-outline-secondary">Cancelar</a>
      <form method="POST" action="/client/addresses/{{address._id}}/delete">
        <button type="submit" class="btn btn-danger">
          <i class="bi bi-trash me-1"></i> Eliminar
        </button>
      </form>
    </div>
  </div>
</div>
