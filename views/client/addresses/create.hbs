<div class="container-fluid mt-2">
  <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div>
      <a href="/client/addresses" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
      </a>
      <h2 class="fw-bold mb-0 text-dark d-inline-block ms-3">Crear dirección</h2>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded p-3">
    <form method="POST" action="/client/addresses/create">
      <div class="mb-3">
        <label class="form-label">Nombre de la dirección</label>
        <input type="text" name="title" class="form-control" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Descripción</label>
        <textarea name="description" class="form-control" rows="3" required></textarea>
      </div>

      <div class="d-flex gap-2">
        <a href="/client/addresses" class="btn btn-outline-secondary w-50">Cancelar</a>
        <button type="submit" class="btn btn-primary w-50">
          <i class="bi bi-check2-circle me-1"></i> Crear
        </button>
      </div>
    </form>
  </div>
</div>
