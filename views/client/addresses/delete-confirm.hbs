<section class="row justify-content-center">
  <div class="col-lg-7">
    <div class="client-form-card text-center">
      <span class="client-eyebrow text-dark bg-light border mb-3">
        <i class="bi bi-exclamation-diamond"></i> Confirmación
      </span>
      <h1 class="client-section-title mb-2">¿Seguro que deseas eliminar esta dirección?</h1>
      <p class="client-muted mb-4">Si confirmas, la dirección <strong>{{address.label}}</strong> dejará de estar
        disponible para tus próximos pedidos.</p>

      <div class="client-panel mb-4 text-start">
        <div class="fw-bold">{{address.label}}</div>
        <div class="client-muted">{{address.description}}</div>
      </div>

      <form action="/client/addresses/delete" method="POST">
        <input type="hidden" name="id" value="{{address._id}}">
        <div class="client-page-actions justify-content-center">
          <a href="/client/addresses" class="btn btn-outline-secondary rounded-pill">Cancelar</a>
          <button type="submit" class="btn btn-danger rounded-pill fw-bold">
            <i class="bi bi-trash3 me-2"></i> Eliminar dirección
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
