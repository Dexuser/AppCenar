<div class="container-fluid mt-2">
  <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div>
      <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
      </a>
      <h2 class="fw-bold mb-0 text-dark d-inline-block ms-3">Checkout</h2>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12 col-lg-7">
      <div class="bg-white shadow-sm rounded p-3">
        <h5 class="fw-bold mb-3">Selecciona una dirección</h5>

        {{#if hasAddresses}}
          <form method="POST" action="/client/checkout">
            {{#each addresses}}
              <div class="form-check border rounded p-3 mb-2">
                <input class="form-check-input" type="radio" name="addressId" id="addr-{{_id}}" value="{{_id}}">
                <label class="form-check-label" for="addr-{{_id}}">
                  <div class="fw-bold">{{title}}</div>
                  <div class="text-muted">{{description}}</div>
                </label>
              </div>
            {{/each}}

            <button type="submit" class="btn btn-success w-100 mt-2">
              <i class="bi bi-bag-check me-1"></i> Pedir
            </button>
          </form>
        {{else}}
          <div class="text-muted">
            No tienes direcciones creadas. Debes crear una dirección para poder continuar.
          </div>
          <a href="/client/addresses" class="btn btn-primary mt-3">
            <i class="bi bi-geo-alt me-1"></i> Ir a Mis direcciones
          </a>
        {{/if}}
      </div>
    </div>

    <div class="col-12 col-lg-5">
      <div class="bg-white shadow-sm rounded p-3">
        <h5 class="fw-bold mb-3">Resumen</h5>

        <div class="d-flex align-items-center gap-2 mb-3">
          <img src="{{commerce.commerceLogo}}" alt="{{commerce.commerceName}}" style="width: 44px; height: 44px; object-fit: cover;" class="rounded-3 border">
          <div>
            <div class="fw-bold">{{commerce.commerceName}}</div>
            <small class="text-muted">Comercio</small>
          </div>
        </div>

        <div class="border rounded p-3 mb-3">
          {{#each cart.items}}
            <div class="d-flex justify-content-between mb-2">
              <div>{{name}}</div>
              <div class="fw-bold">RD$ {{price}}</div>
            </div>
          {{/each}}
        </div>

        <div class="border-top pt-3">
          <div class="d-flex justify-content-between mb-2">
            <div class="text-muted">Subtotal</div>
            <div class="fw-bold">RD$ {{subtotal}}</div>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <div class="text-muted">ITBIS ({{itebis}}%)</div>
            <div class="fw-bold">{{!-- se calcula en backend dentro del total --}}</div>
          </div>
          <div class="d-flex justify-content-between">
            <div class="fw-bold">Total</div>
            <div class="fw-bold">RD$ {{total}}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
