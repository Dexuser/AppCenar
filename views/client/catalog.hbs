<div class="container-fluid mt-2">
  <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div class="d-flex align-items-center gap-3">
      <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
      </a>
      <div class="d-flex align-items-center gap-2">
        <img src="{{commerce.commerceLogo}}" alt="{{commerce.commerceName}}" style="width: 44px; height: 44px; object-fit: cover;" class="rounded-3 border">
        <div>
          <div class="fw-bold">{{commerce.commerceName}}</div>
          <small class="text-muted">Catálogo</small>
        </div>
      </div>
    </div>

    <div>
      {{#if hasCartItems}}
        <a href="/client/checkout" class="btn btn-success btn-sm">
          <i class="bi bi-bag-check me-1"></i> Continuar
        </a>
      {{/if}}
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12 col-lg-8">
      {{#if hasCatalog}}
        {{#each catalog}}
          <div class="bg-white shadow-sm rounded p-3 mb-3">
            <h5 class="fw-bold mb-0">{{name}}</h5>
            <small class="text-muted">{{description}}</small>

            {{#if hasProducts}}
              <div class="row g-3 mt-2">
                {{#each products}}
                  <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                      <div class="card-body">
                        <div class="d-flex gap-3">
                          <img src="{{image}}" alt="{{name}}" style="width: 74px; height: 74px; object-fit: cover;" class="rounded-3 border">
                          <div class="flex-grow-1">
                            <div class="fw-bold">{{name}}</div>
                            <div class="text-muted" style="font-size: 0.9rem;">{{description}}</div>
                            <div class="fw-bold mt-2">RD$ {{price}}</div>
                          </div>
                        </div>

                        <div class="mt-3">
                          {{#if inCart}}
                            <button class="btn btn-outline-secondary w-100" disabled>
                              <i class="bi bi-check2 me-1"></i> Agregado
                            </button>
                          {{else}}
                            <form method="POST" action="/client/catalog/{{../../commerce._id}}/cart/add" class="d-grid">
                              <input type="hidden" name="productId" value="{{_id}}">
                              <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Agregar
                              </button>
                            </form>
                          {{/if}}
                        </div>
                      </div>
                    </div>
                  </div>
                {{/each}}
              </div>
            {{else}}
              <div class="text-muted mt-3">No hay productos en esta categoría.</div>
            {{/if}}
          </div>
        {{/each}}
      {{else}}
        <div class="bg-white shadow-sm rounded p-5 text-center">
          <i class="bi bi-box-seam text-muted display-1"></i>
          <h4 class="mt-3 text-muted">Este comercio no tiene productos</h4>
        </div>
      {{/if}}

      {{#if hasUncategorized}}
        <div class="bg-white shadow-sm rounded p-3 mb-3">
          <h5 class="fw-bold mb-0">Sin categoría</h5>
          <div class="row g-3 mt-2">
            {{#each uncategorized}}
              <div class="col-12 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                  <div class="card-body">
                    <div class="d-flex gap-3">
                      <img src="{{image}}" alt="{{name}}" style="width: 74px; height: 74px; object-fit: cover;" class="rounded-3 border">
                      <div class="flex-grow-1">
                        <div class="fw-bold">{{name}}</div>
                        <div class="text-muted" style="font-size: 0.9rem;">{{description}}</div>
                        <div class="fw-bold mt-2">RD$ {{price}}</div>
                      </div>
                    </div>

                    <div class="mt-3">
                      {{#if inCart}}
                        <button class="btn btn-outline-secondary w-100" disabled>
                          <i class="bi bi-check2 me-1"></i> Agregado
                        </button>
                      {{else}}
                        <form method="POST" action="/client/catalog/{{../commerce._id}}/cart/add" class="d-grid">
                          <input type="hidden" name="productId" value="{{_id}}">
                          <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i> Agregar
                          </button>
                        </form>
                      {{/if}}
                    </div>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}
    </div>

    <div class="col-12 col-lg-4">
      <div class="bg-white shadow-sm rounded p-3 sticky-top" style="top: 12px;">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0">Mi pedido</h5>
          {{#if hasCartItems}}
            <form method="POST" action="/client/cart/clear">
              <button type="submit" class="btn btn-sm btn-outline-danger">Limpiar</button>
            </form>
          {{/if}}
        </div>

        {{#if hasCartItems}}
          <div class="mt-3">
            {{#each cart.items}}
              <div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2">
                <div>
                  <div class="fw-bold">{{name}}</div>
                  <small class="text-muted">RD$ {{price}}</small>
                </div>
                <form method="POST" action="/client/catalog/{{../commerce._id}}/cart/remove">
                  <input type="hidden" name="productId" value="{{productId}}">
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x"></i>
                  </button>
                </form>
              </div>
            {{/each}}
          </div>

          <div class="border-top pt-3 mt-2">
            <div class="d-flex justify-content-between">
              <div class="fw-bold">Subtotal</div>
              <div class="fw-bold">RD$ {{cart.subtotal}}</div>
            </div>

            <a href="/client/checkout" class="btn btn-success w-100 mt-3">
              <i class="bi bi-arrow-right-circle me-1"></i> Continuar
            </a>
          </div>
        {{else}}
          <div class="text-center text-muted py-4">
            <i class="bi bi-bag display-6"></i>
            <div class="mt-2">Tu pedido está vacío</div>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>
