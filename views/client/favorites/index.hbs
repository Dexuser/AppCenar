<div class="container-fluid mt-2">
  <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
    <div>
      <a href="/client/home" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
      </a>
      <h2 class="fw-bold mb-0 text-dark d-inline-block ms-3">Mis favoritos</h2>
    </div>
  </div>

  {{#if hasFavorites}}
    <div class="row g-3">
      {{#each favorites}}
        <div class="col-12 col-lg-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex align-items-center gap-3">
                <a href="/client/catalog/{{commerceId._id}}" class="text-decoration-none flex-grow-1">
                  <img 
                    src="{{commerceId.commerceLogo}}" 
                    alt="{{commerceId.commerceName}}"
                    style="width: 64px; height: 64px; object-fit: cover;"
                    class="rounded-3 border"
                  >
                  <div>
                    <div class="fw-bold text-dark">{{commerceId.commerceName}}</div>
                    <small class="text-muted">Ver catálogo</small>
                  </div>
                </a>

                <form method="POST" action="/client/favorites/{{commerceId._id}}/remove">
                  <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-x"></i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="bg-white shadow-sm rounded p-5 text-center">
      <i class="bi bi-heart text-muted display-1"></i>
      <h4 class="mt-3 text-muted">No tienes comercios favoritos</h4>
      <a href="/client/home" class="btn btn-primary mt-2">
        <i class="bi bi-house-door me-1"></i> Ir al home
      </a>
    </div>
  {{/if}}
</div>
