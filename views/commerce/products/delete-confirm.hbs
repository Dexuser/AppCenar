<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-5">
                <i class="bi bi-trash3 text-danger display-1 mb-4"></i>
                <h3 class="fw-bold">¿Está seguro que desea eliminar este producto?</h3>
                <p class="text-muted mb-4">El producto <strong>{{product.name}}</strong> se eliminará de forma
                    permanente.</p>

                <form action="/commerce/products/delete" method="POST">
                    <input type="hidden" name="id" value="{{product._id}}">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill">Aceptar e Eliminar</button>
                        <a href="/commerce/products" class="btn btn-light btn-lg rounded-pill border">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>