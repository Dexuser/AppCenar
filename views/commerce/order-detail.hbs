<div class="container py-4" style="max-width: 700px;">
    <div class="d-flex align-items-center mb-4">
        <a href="/commerce" class="btn btn-back-modern shadow-sm me-3">
            <i class="bi bi-chevron-left"></i>
            <span>Volver</span>
        </a>
        <h4 class="fw-bold mb-0">Detalle del Pedido</h4>
    </div>

    {{#if error}}
    <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
        <div>{{error}}</div>
    </div>
    {{/if}}

    <div class="card border-0 shadow-sm rounded-4 p-4 text-center mb-4">
        <div class="bg-danger d-inline-block p-3 rounded-4 mb-3 mx-auto shadow-sm">
            <i class="bi bi-bag-check-fill text-white fs-1"></i>
        </div>
        <h3 class="fw-bold mb-1">{{order.commerce.name}}</h3>
        <div class="d-flex justify-content-center gap-2 align-items-center">
            <span class="badge bg-dark px-3 py-2 text-uppercase">{{order.status}}</span>
        </div>
        <p class="text-muted mt-3 small">Realizado el: {{formattedDate}}</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <h5 class="fw-bold mb-4 border-bottom pb-2">Tu pedido</h5>
        {{#each order.items}}
        <div class="d-flex align-items-center mb-4">
            <img src="{{this.image}}" class="rounded-3 shadow-sm me-3"
                style="width: 70px; height: 70px; object-fit: cover;">
            <div class="flex-grow-1">
                <h6 class="fw-bold mb-0">{{this.name}}</h6>
                <small class="text-muted">Precio Unitario: RD$ {{this.price}}</small>
            </div>
            <span class="fw-bold text-dark">RD$ {{this.price}}</span>
        </div>
        {{/each}}

        <hr class="my-4 text-muted">

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted">Subtotal</span>
            <span class="fw-medium">RD$ {{order.subtotal}}</span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">ITBIS (18%)</span>
            <span class="fw-medium">RD$ {{order.itbisAmount}}</span>
        </div>
        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
            <h4 class="fw-bold mb-0">Total</h4>
            <h3 class="fw-bold text-danger mb-0">RD$ {{order.total}}</h3>
        </div>
    </div>

    {{#if isPending}}
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-light">
        <p class="text-center text-muted small mb-3">
            Busca un repartidor disponible para iniciar la entrega.
        </p>
        <form action="/commerce/assign-delivery" method="POST">
            <input type="hidden" name="orderId" value="{{order._id}}">
            <button type="submit" class="btn btn-danger btn-lg w-100 rounded-pill fw-bold shadow-sm py-3">
                <i class="bi bi-bicycle me-2"></i>Asignar delivery
            </button>
        </form>
    </div>
    {{else}}
    {{#if order.delivery.deliveryId}}
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
        <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Repartidor Asignado</h6>
        <div class="d-flex align-items-center">
            <div class="flex-grow-1">
                <p class="mb-0 fw-bold">{{order.delivery.firstName}} {{order.delivery.lastName}}</p>
                <small class="opacity-75">Tel: {{order.delivery.phone}}</small>
            </div>
            <i class="bi bi-person-badge display-6 opacity-50"></i>
        </div>
    </div>
    {{/if}}
    {{/if}}
</div>