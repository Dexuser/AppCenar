<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-4 d-flex align-items-center justify-content-between">
                <div>
                    <h2 class="fw-bold mb-0 text-dark">
                        {{#if editMode}} <i class="bi bi-pencil-square text-primary me-2"></i> Editar Categoría
                        {{else}} <i class="bi bi-plus-circle-fill text-success me-2"></i> Nueva Categoría {{/if}}
                    </h2>
                    <p class="text-muted small">Todos los campos marcados con (*) son obligatorios</p>
                </div>
                <a href="/commerce/categories" class="btn btn-light rounded-pill px-3 shadow-sm border">
                    <i class="bi bi-arrow-left me-1"></i> Volver al listado
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">

                    {{#if hasErrors}}
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                        <ul class="mb-0 small">
                            {{#each errors}}
                            <li>{{this}}</li>
                            {{/each}}
                        </ul>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {{/if}}

                    <form
                        action="{{#if editMode}}/commerce/categories/edit/{{category._id}}{{else}}/commerce/categories/create{{/if}}"
                        method="POST">

                        <div class="mb-4">
                            <label for="name" class="form-label fw-bold text-secondary small text-uppercase">Nombre de
                                la Categoría *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i
                                        class="bi bi-tag-fill text-primary"></i></span>
                                <input type="text" id="name" name="name" class="form-control bg-light border-0"
                                    placeholder="Ej: Entradas, Pizzas, Postres..." value="{{category.name}}" required>
                            </div>
                        </div>

                        <div class="mb-5">
                            <label for="description"
                                class="form-label fw-bold text-secondary small text-uppercase">Descripción *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 align-items-start pt-2"><i
                                        class="bi bi-chat-left-text-fill text-primary"></i></span>
                                <textarea id="description" name="description" class="form-control bg-light border-0"
                                    rows="4"
                                    placeholder="Describe brevemente qué platos o productos incluye esta categoría..."
                                    required>{{category.description}}</textarea>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end pt-3 border-top">
                            <a href="/commerce/categories"
                                class="btn btn-light rounded-pill px-4 fw-bold text-muted border me-md-2">
                                Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                {{#if editMode}}Guardar cambios{{else}}Crear categoría{{/if}}
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>