<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Mantenimiento de Categorías</h2>
            <p class="text-muted">Administra las agrupaciones de tus productos</p>
        </div>
        <a href="/commerce/categories/create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Crear Nueva Categoría
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold text-secondary">Categoría</th>
                            <th class="py-3 text-uppercase small fw-bold text-secondary">Descripción</th>
                            <th class="py-3 text-uppercase small fw-bold text-secondary text-center">Productos</th>
                            <th class="pe-4 py-3 text-uppercase small fw-bold text-secondary text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if hasCategories}}
                        {{#each categories}}
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">{{this.name}}</span>
                            </td>
                            <td>
                                <span class="text-muted small">{{this.description}}</span>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3">
                                    {{this.productCount}} ítems
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    <a href="/commerce/categories/edit/{{this._id}}"
                                        class="btn btn-white btn-sm px-3 border-end" title="Editar">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </a>
                                    <a href="/commerce/categories/delete/{{this._id}}" class="btn btn-white btn-sm px-3"
                                        title="Eliminar">
                                        <i class="bi bi-trash3 text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                        {{else}}
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-tags display-1 text-light"></i>
                                    <p class="mt-3 text-muted">No has creado ninguna categoría aún.</p>
                                    <a href="/commerce/categories/create"
                                        class="btn btn-link text-primary fw-bold">Comienza creando la primera</a>
                                </div>
                            </td>
                        </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>