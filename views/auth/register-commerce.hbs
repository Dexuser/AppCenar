<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-7">
    <div class="card shadow border-0 rounded-4">
      <div class="card-header bg-success text-white py-3">
        <h4 class="mb-0 text-center">
          <i class="bi bi-shop"></i>
          Registro de Comercio
        </h4>
      </div>

      <div class="card-body p-4">

        <form action="/user/register-commerce" method="POST" enctype="multipart/form-data">

          <div class="mb-3">
            <label for="commerceName-input" class="form-label fw-bold">Nombre del Comercio</label>
            <input type="text" class="form-control" id="commerceName-input" name="commerceName"
              placeholder="Ej: Pizzería La Romana" required />
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="phone-input" class="form-label fw-bold">Número de Teléfono</label>
              <input type="text" class="form-control" id="phone-input" name="phone" placeholder="Ej: 809-555-5555"
                required />
            </div>

            <div class="col-md-6 mb-3">
              <label for="email-input" class="form-label fw-bold">Correo Electrónico</label>
              <input type="email" class="form-control" id="email-input" name="email" placeholder="negocio@ejemplo.com"
                required />
            </div>
          </div>

          <div class="mb-3">
            <label for="logo-input" class="form-label fw-bold">Logo del Comercio</label>
            <input type="file" class="form-control" id="logo-input" name="logo"
              accept="image/png, image/jpeg, image/jpg" required />
            <small class="text-muted">Formatos permitidos: JPG, JPEG, PNG</small>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="openingHour-input" class="form-label fw-bold">Hora de Apertura</label>
              <input type="time" class="form-control" id="openingHour-input" name="openTime" required />
            </div>

            <div class="col-md-6 mb-3">
              <label for="closingHour-input" class="form-label fw-bold">Hora de Cierre</label>
              <input type="time" class="form-control" id="closingHour-input" name="closeTime" required />
            </div>
          </div>

          <div class="mb-3">
            <label for="commerceType-input" class="form-label fw-bold">Tipo de Comercio</label>
            <select class="form-select" id="commerceType-input" name="commerceTypeId" required>
              <option value="">Seleccione un tipo de comercio</option>
              {{#each commerceTypes}}
              <option value="{{this._id}}" {{#if (Equals ../commerceTypeId this._id)}}selected{{/if}}>
                {{this.title}}
              </option>
              {{/each}}
            </select>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="password-input" class="form-label fw-bold">Contraseña</label>
              <input type="password" class="form-control" id="password-input" name="password" minlength="8"
                placeholder="••••••••" required />
              <small class="text-muted">Mínimo 8 caracteres</small>
            </div>

            <div class="col-md-6 mb-3">
              <label for="confirmPassword-input" class="form-label fw-bold">Confirmar Contraseña</label>
              <input type="password" class="form-control" id="confirmPassword-input" name="confirmPassword"
                minlength="8" placeholder="••••••••" required />
            </div>
          </div>

          <div class="alert alert-info border-0 shadow-sm rounded-3">
            <i class="bi bi-info-circle-fill me-2"></i>
            Una vez registrado, la cuenta de su comercio permanecerá inactiva hasta que confirme su correo electrónico a
            través del enlace de activación.
          </div>

          <div class="d-flex justify-content-end gap-2 pt-3 border-top">
            <a href="/user/register-select" class="btn btn-warning rounded-pill px-4 fw-bold">
              <i class="bi bi-arrow-left"></i> Atrás
            </a>
            <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">
              <i class="bi bi-shop"></i> Registrar Comercio
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>