{{#section 'styles'}}
<link rel="stylesheet" href="/assets/css/site/login.css" />
{{/section}}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card login-card">
            <div class="login-header">
                <h4 class="mb-0"><i class="bi bi-shield-lock"></i> Acceso al Sistema</h4>
            </div>

            <div class="card-body p-4">
                <form action="/" method="POST">
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="email" name="Email"
                            placeholder="nombre@ejemplo.com" required>
                        <label for="email">Correo Electrónico</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="password" name="Password"
                            placeholder="Contraseña" required>
                        <label for="password">Contraseña</label>
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-login btn-lg shadow-sm">
                            Iniciar Sesión
                        </button>
                    </div>

                    <hr>

                    <div class="text-center">
                        <a href="/user/register-select" class="d-block mb-2 text-decoration-none text-primary">
                            <i class="bi bi-person-plus"></i> Regístrate
                        </a>
                        <a href="/user/forgot" class="text-decoration-none text-muted small">
                            <i class="bi bi-question-circle"></i> Olvidé mi contraseña
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>