<div class="row justify-content-center mt-5">
  <div class="col-12 col-md-10 col-lg-8">

    <div class="text-center mb-4">
      <h2>
        <i class="bi bi-person-plus-fill"></i>
        Create an Account
      </h2>
      <p class="text-muted">
        Select the type of account you want to register.
      </p>
    </div>

    <div class="row g-4">

      <div class="col-md-6">
        <div class="card shadow h-100 border-0">
          <div class="card-body text-center p-4 d-flex flex-column">
            <div class="mb-3">
              <i class="bi bi-person-badge display-3 text-primary"></i>
            </div>

            <h4>User Account</h4>

            <p class="text-muted flex-grow-1">
              Register as a client or delivery user to place orders or deliver them.
            </p>

            <ul class="list-group list-group-flush mb-4 text-start">
              <li class="list-group-item">
                <i class="bi bi-check-circle text-success"></i>
                Register as Client
              </li>
              <li class="list-group-item">
                <i class="bi bi-check-circle text-success"></i>
                Register as Delivery
              </li>
              <li class="list-group-item">
                <i class="bi bi-check-circle text-success"></i>
                Activate account by email
              </li>
            </ul>

            <a href="/user/register-user" class="btn btn-primary w-100">
              <i class="bi bi-arrow-right-circle"></i>
              Register as User
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card shadow h-100 border-0">
          <div class="card-body text-center p-4 d-flex flex-column">
            <div class="mb-3">
              <i class="bi bi-shop display-3 text-success"></i>
            </div>

            <h4>Commerce Account</h4>

            <p class="text-muted flex-grow-1">
              Register your business and start receiving orders through the platform.
            </p>

            <ul class="list-group list-group-flush mb-4 text-start">
              <li class="list-group-item">
                <i class="bi bi-check-circle text-success"></i>
                Register your business
              </li>
              <li class="list-group-item">
                <i class="bi bi-check-circle text-success"></i>
                Manage products and orders
              </li>
              <li class="list-group-item">
                <i class="bi bi-check-circle text-success"></i>
                Activate account by email
              </li>
            </ul>

            <a href="/user/register-commerce" class="btn btn-success w-100">
              <i class="bi bi-arrow-right-circle"></i>
              Register as Commerce
            </a>
          </div>
        </div>
      </div>

    </div>

    <div class="text-center mt-4">
      <a href="/" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Login
      </a>
    </div>

  </div>
</div>
