<div class="row justify-content-center mt-5">
  <div class="col-12 col-md-10 col-lg-8">

    <div class="text-center mb-4">
      <h2 class="fw-bold">
        <i class="bi bi-person-plus-fill text-primary"></i>
        Crear una Cuenta
      </h2>
      <p class="text-muted">
        Selecciona el tipo de cuenta que deseas registrar para comenzar.
      </p>
    </div>

    <div class="row g-4">

      <div class="col-md-6">
        <div class="card shadow-sm h-100 border-0 rounded-4">
          <div class="card-body text-center p-4 d-flex flex-column">
            <div class="mb-3">
              <i class="bi bi-person-badge display-3 text-primary"></i>
            </div>

            <h4 class="fw-bold">Cuenta de Usuario</h4>

            <p class="text-muted flex-grow-1">
              Regístrate como cliente para realizar pedidos o como repartidor para entregarlos.
            </p>

            <ul class="list-group list-group-flush mb-4 text-start small">
              <li class="list-group-item bg-transparent">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                Registro como Cliente
              </li>
              <li class="list-group-item bg-transparent">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                Registro como Repartidor
              </li>
              <li class="list-group-item bg-transparent">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                Activación por correo electrónico
              </li>
            </ul>

            <a href="/user/register-user" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">
              <i class="bi bi-arrow-right-circle me-1"></i>
              Registrarme como Usuario
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card shadow-sm h-100 border-0 rounded-4">
          <div class="card-body text-center p-4 d-flex flex-column">
            <div class="mb-3">
              <i class="bi bi-shop display-3 text-success"></i>
            </div>

            <h4 class="fw-bold">Cuenta de Comercio</h4>

            <p class="text-muted flex-grow-1">
              Registra tu negocio y empieza a recibir pedidos a través de nuestra plataforma.
            </p>

            <ul class="list-group list-group-flush mb-4 text-start small">
              <li class="list-group-item bg-transparent">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                Registra tu negocio propio
              </li>
              <li class="list-group-item bg-transparent">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                Gestiona productos y pedidos
              </li>
              <li class="list-group-item bg-transparent">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                Activación por correo electrónico
              </li>
            </ul>

            <a href="/user/register-commerce" class="btn btn-success w-100 rounded-pill py-2 fw-bold">
              <i class="bi bi-arrow-right-circle me-1"></i>
              Registrarme como Comercio
            </a>
          </div>
        </div>
      </div>

    </div>

    <div class="text-center mt-5">
      <a href="/" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left me-1"></i>
        Volver al Login
      </a>
    </div>

  </div>
</div>