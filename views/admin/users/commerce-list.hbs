<div class="container-fluid mt-4">
    <div class="admin-card p-4 bg-white shadow-sm rounded-4 border-top border-4 border-commerce">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark mb-0">
                <i class="bi bi-shop icon-commerce me-2"></i> Gestión de Comercios
            </h2>
            <span class="badge bg-dark rounded-pill px-3 py-2">Registrados: {{commerces.length}}</span>
        </div>

        {{#if hasCommerces}}
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Logo</th>
                        <th>Comercio / Tipo</th>
                        <th class="text-center">Pedidos</th>
                        <th>Teléfono</th>
                        <th class="text-center">Horario</th>
                        <th>Correo</th>
                        <th class="text-end pe-4">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each commerces}}
                    <tr>
                        <td class="ps-4">
                            <img src="{{this.commerceLogo}}" alt="Logo" class="rounded-3 shadow-sm border"
                                style="width: 55px; height: 55px; object-fit: cover;">
                        </td>
                        <td>
                            <div class="fw-bold text-dark">{{this.commerceName}}</div>
                            <small class="text-muted text-uppercase" style="font-size: 0.7rem;">
                                {{#if this.commerceTypeId}}{{this.commerceTypeId.title}}{{else}}Sin Categoría{{/if}}
                            </small>
                        </td>
                        <td class="text-center">
                            <span
                                class="badge bg-primary-subtle text-primary border border-primary border-opacity-25 px-3">
                                <i class="bi bi-box-seam me-1"></i> {{this.orderCount}}
                            </span>
                        </td>
                        <td>{{#if this.phone}}{{this.phone}}{{else}}---{{/if}}</td>
                        <td class="text-center">
                            <div class="small fw-bold text-success">{{this.openTime}}</div>
                            <div class="small fw-bold text-danger">{{this.closeTime}}</div>
                        </td>
                        <td><small>{{this.email}}</small></td>
                        <td class="text-end pe-4">
                            <form action="/admin/commerces/toggle-status/{{this._id}}" method="POST" class="m-0">
                                {{#if this.isActive}}
                                <button type="submit" class="btn btn-danger btn-sm px-3 rounded-pill">
                                    Inactivar
                                </button>
                                {{else}}
                                <button type="submit" class="btn btn-success btn-sm px-3 rounded-pill">
                                    Activar
                                </button>
                                {{/if}}
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="text-center py-5 bg-light rounded-4">
            <i class="bi bi-shop-window display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No hay comercios para mostrar</h4>
        </div>
        {{/if}}
    </div>
</div>