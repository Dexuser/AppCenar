<div class="container-fluid mt-4">
    <div class="admin-card p-4 bg-white shadow-sm rounded-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark mb-0">
                <i class="bi bi-bicycle icon-delivery me-2"></i> Listado de Delivery
            </h2>
            <div class="badge bg-dark rounded-pill px-3 py-2">Total: {{deliveries.length}}</div>
        </div>

        {{#if hasDeliveries}}
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Nombre</th>
                        <th>Apellido</th>
                        <th class="text-center">Pedidos Entregados</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end pe-4">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each deliveries}}
                    <tr>
                        <td class="ps-4">{{this.firstName}}</td>
                        <td>{{this.lastName}}</td>
                        <td class="text-center">
                            <span class="badge bg-orange text-white rounded-pill px-3"
                                style="background-color: #fd7e14;">
                                {{this.deliveredCount}} entregas
                            </span>
                        </td>
                        <td>{{#if this.phone}}{{this.phone}}{{else}}---{{/if}}</td>
                        <td>{{this.email}}</td>
                        <td class="text-center">
                            {{#if this.isActive}}
                            <span class="text-success small fw-bold">ACTIVO</span>
                            {{else}}
                            <span class="text-danger small fw-bold">INACTIVO</span>
                            {{/if}}
                        </td>
                        <td class="text-end pe-4">
                            <form action="/admin/delivery/toggle-status/{{this._id}}" method="POST" class="m-0">
                                {{#if this.isActive}}
                                <button type="submit" class="btn btn-outline-danger btn-sm px-4 rounded-pill">
                                    Inactivar
                                </button>
                                {{else}}
                                <button type="submit" class="btn btn-success btn-sm px-4 rounded-pill">
                                    Activar
                                </button>
                                {{/if}}
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="text-center py-5 border rounded-3 bg-light">
            <i class="bi bi-bicycle fs-1 text-muted"></i>
            <p class="mt-2 mb-0">No hay repartidores registrados en el sistema.</p>
        </div>
        {{/if}}
    </div>
</div>