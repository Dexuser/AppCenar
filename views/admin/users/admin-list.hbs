<div class="container-fluid mt-4">
    <div class="admin-card p-4 bg-white shadow-sm rounded-4 border-top border-4 border-dark">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold"><i class="bi bi-shield-lock-fill me-2"></i> Administradores</h2>
            <a href="/admin/admins-management/create" class="btn btn-dark rounded-pill px-4">Crear Administrador</a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nombre Completo</th>
                        <th>Cédula</th>
                        <th>Usuario</th>
                        <th>Correo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each admins}}
                    <tr>
                        <td>{{this.firstName}} {{this.lastName}}</td>
                        <td>{{this.cedula}}</td>
                        <td><span class="badge bg-secondary">{{this.username}}</span></td>
                        <td>{{this.email}}</td>
                        <td class="text-end">
                            {{#if this.isCurrentUser}}
                            <span class="badge bg-info-subtle text-info">Tú (Sesión activa)</span>
                            {{else}}
                            <a href="/admin/admins-management/edit/{{this._id}}"
                                class="btn btn-sm btn-outline-warning rounded-pill px-3">Editar</a>

                            <form action="/admin/admins-management/toggle-status/{{this._id}}" method="POST"
                                class="d-inline form-toggle-status"> <button type="button"
                                    class="btn btn-sm {{#if this.isActive}}btn-outline-danger{{else}}btn-success{{/if}} rounded-pill px-3 btn-toggle"
                                    data-action="{{#if this.isActive}}inactivar{{else}}activar{{/if}}"> {{#if
                                    this.isActive}}Inactivar{{else}}Activar{{/if}}
                                </button>
                            </form>
                            {{/if}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>


<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Seleccionamos todos los botones de activar/inactivar
        const toggleButtons = document.querySelectorAll('.btn-toggle');

        toggleButtons.forEach(button => {
            button.addEventListener('click', function (e) {
                const action = this.getAttribute('data-action');
                const form = this.closest('.form-toggle-status');

                // Aquí lanzamos la caja linda
                Swal.fire({
                    title: `¿Estás seguro?`,
                    text: `¿Realmente deseas ${action} a este administrador?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: action === 'inactivar' ? '#d33' : '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, continuar',
                    cancelButtonText: 'Cancelar',
                    border: 'none',
                    borderRadius: '15px'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Si el usuario dijo que "Si", enviamos el formulario
                        form.submit();
                    }
                });
            });
        });
    });
</script>