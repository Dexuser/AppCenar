<div class="container" style="max-width: 600px; margin-top: 100px;">
    <div class="delete-container text-center shadow">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
        <h2 class="mt-3">¿Estás seguro?</h2>
        <p class="lead mb-4 text-muted">
            ¿Está seguro que desea eliminar este tipo de comercio: <strong>"{{type.title}}"</strong> y todos los
            comercios asociados a este tipo?
        </p>

        <form action="/admin/commerce-types/delete" method="POST">
            <input type="hidden" name="id" value="{{type._id}}">

            <div class="d-flex justify-content-center gap-3 ">
                <a href="/admin/commerce-types" class="btn btn-lg btn-outline-secondary px-5">
                    Cancelar
                </a>
                <button type="submit" class="btn btn-lg btn-danger px-5">
                    Aceptar y Eliminar
                </button>
            </div>
        </form>
    </div>
</div>