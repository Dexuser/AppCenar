<div class="container-fluid mt-2">
    <div
        class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded border-start border-4 border-type">
        <div>
            <h2 class="fw-bold mb-0 text-dark">
                <i class="bi bi-tags-fill icon-type me-2"></i>Mantenimiento de Tipos de Comercios
            </h2>
            <small class="text-muted">Gestiona las categorías principales para los comercios de la plataforma</small>
        </div>
        <a href="/admin/commerce-types/create" class="btn btn-primary btn-lg shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>Crear Nuevo Tipo
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            {{#if hasTypes}}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4 py-3" style="width: 100px;">Icono</th>
                            <th class="py-3">Nombre Categoría</th>
                            <th class="py-3" style="width: 40%;">Descripción</th>
                            <th class="text-center py-3">Comercios Asociados</th>
                            <th class="text-end pe-4 py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each types}}
                        <tr>
                            <td class="ps-4">
                                <div class="bg-light rounded-3 p-1 d-inline-block border">
                                    <img src="{{this.image}}" alt="{{this.title}}" class="admin-table-img shadow-sm"
                                        style="width: 60px; height: 60px;">
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold fs-5 text-dark">{{this.title}}</span>
                            </td>
                            <td>
                                <p class="text-muted mb-0 small text-truncate" style="max-width: 400px;">
                                    {{this.description}}
                                </p>
                            </td>
                            <td class="text-center">
                                <span
                                    class="badge rounded-pill bg-soft-primary px-4 py-2 text-primary border border-primary border-opacity-25">
                                    <i class="bi bi-shop me-1"></i> {{this.commerceCount}}
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="/admin/commerce-types/edit/{{this._id}}"
                                        class="btn btn-outline-warning btn-sm px-3 border-2" title="Editar Categoría">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/admin/commerce-types/delete/{{this._id}}"
                                        class="btn btn-outline-danger btn-sm px-3 border-2" title="Eliminar Categoría">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <div class="text-center py-5">
                <i class="bi bi-folder-x text-muted display-1"></i>
                <h4 class="mt-3 text-muted">No se encontraron registros</h4>
                <p class="text-secondary">Comienza creando una nueva categoría de comercio para mostrarla aquí.</p>
                <a href="/admin/commerce-types/create" class="btn btn-primary mt-2">Crear mi primer tipo</a>
            </div>
            {{/if}}
        </div>
    </div>
</div>