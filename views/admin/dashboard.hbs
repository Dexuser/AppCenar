<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="card stat-card h-100 border-start border-primary border-5">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-3">
                        <div>
                            <p class="text-muted fw-bold small mb-1">PEDIDOS HISTÓRICOS</p>
                            <h2 class="fw-black text-dark mb-0">{{stats.orders.total}}</h2>
                        </div>
                        <div class="icon-shape-lg bg-primary text-white shadow-sm">
                            <i class="bi bi-receipt"></i>
                        </div>
                    </div>
                    <div class="bg-light p-2 rounded-3 border">
                        <span class="text-primary fw-bold small">
                            <i class="bi bi-graph-up-arrow me-1"></i> +{{stats.orders.today}} registrados hoy
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="card stat-card h-100 border-start border-dark border-5">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-3">
                        <div>
                            <p class="text-muted fw-bold small mb-1">CATÁLOGO TOTAL</p>
                            <h2 class="fw-black text-dark mb-0">{{stats.products}}</h2>
                        </div>
                        <div class="icon-shape-lg bg-dark text-white shadow-sm">
                            <i class="bi bi-box-seam"></i>
                        </div>
                    </div>
                    <p class="mb-0 text-muted small"><i class="bi bi-info-circle me-1"></i> Productos en almacén virtual
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-12">
            <div class="card stat-card h-100 border-start border-success border-5">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-shape-lg bg-success bg-opacity-10 text-success me-3">
                            <i class="bi bi-shop"></i>
                        </div>
                        <h6 class="fw-bold mb-0">Balance de Comercios</h6>
                    </div>
                    <div class="progress mb-3 border" style="height: 15px; background-color: #f8f9fa;">
                        <div class="progress-bar bg-success" style="width: {{stats.commerces.activePct}}%"></div>
                        <div class="progress-bar bg-danger" style="width: {{stats.commerces.inactivePct}}%"></div>
                    </div>
                    <div class="d-flex justify-content-between px-1">
                        <span class="small fw-bold text-success">{{stats.commerces.active}} Activos</span>
                        <span class="small fw-bold text-danger">{{stats.commerces.inactive}} Inactivos</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card stat-card">
                <div class="card-header bg-transparent border-bottom p-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-people-fill text-warning me-2"></i>Gestión de
                        Clientes</h6>
                </div>
                <div class="card-body p-0">
                    <div class="row g-0">
                        <div class="col-6 p-4 border-end text-center bg-light bg-opacity-25">
                            <span class="d-block text-muted small fw-bold">ACTIVOS</span>
                            <h2 class="fw-bold text-success mt-1">{{stats.clients.active}}</h2>
                        </div>
                        <div class="col-6 p-4 text-center">
                            <span class="d-block text-muted small fw-bold">INACTIVOS</span>
                            <h2 class="fw-bold text-danger mt-1">{{stats.clients.inactive}}</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card stat-card">
                <div class="card-header bg-transparent border-bottom p-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-bicycle text-info me-2"></i>Estado de Deliveries
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="row g-0">
                        <div class="col-6 p-4 border-end text-center bg-light bg-opacity-25">
                            <span class="d-block text-muted small fw-bold">ACTIVOS</span>
                            <h2 class="fw-bold text-info mt-1">{{stats.deliveries.active}}</h2>
                        </div>
                        <div class="col-6 p-4 text-center">
                            <span class="d-block text-muted small fw-bold">INACTIVOS</span>
                            <h2 class="fw-bold text-secondary mt-1">{{stats.deliveries.inactive}}</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>