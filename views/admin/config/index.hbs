<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="admin-card p-0 bg-white shadow-sm rounded-4 border-top border-4 border-dark">
                <div class="p-4 text-center border-bottom bg-light">
                    <h2 class="fw-bold mb-0">
                        <i class="bi bi-gear-wide-connected text-secondary me-2"></i>Configuración
                    </h2>
                </div>

                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <p class="text-muted text-uppercase fw-semibold mb-1 small tracking-wider">Impuesto sobre Ventas
                        </p>
                        <div class="d-flex align-items-center justify-content-center">
                            <h1 class="display-2 fw-black text-dark mb-0">{{config.itebis}}</h1>
                            <span class="display-5 fw-light text-muted ms-2">%</span>
                        </div>
                        <span class="badge bg-dark-subtle text-dark px-3 py-2 rounded-pill mt-3">ITBIS Actual</span>
                    </div>

                    <hr class="my-4 opacity-25">

                    <div class="d-grid">
                        <a href="/admin/config/edit" class="btn btn-warning btn-lg rounded-pill fw-bold shadow-sm py-3">
                            <i class="bi bi-pencil-square me-2"></i> Editar Configuración
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 pb-4 text-center">
                    <small class="text-muted italic">Última actualización: {{#if
                        config.updatedAt}}{{config.updatedAt}}{{else}}N/A{{/if}}</small>
                </div>
            </div>
        </div>
    </div>
</div>