<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-warning text-dark py-3 fw-bold text-center border-0 rounded-top-4">
                    <h5 class="mb-0"><i class="bi bi-pencil-fill me-2"></i>Modificar ITBIS</h5>
                </div>

                <div class="card-body p-4">
                    <form action="/admin/config/edit" method="POST">
                        <div class="mb-4">
                            <label for="itebis" class="form-label fw-bold text-secondary">Valor del ITBIS (%)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="bi bi-percent"></i>
                                </span>
                                <input type="number" id="itebis" name="itebis"
                                    class="form-control border-start-0 text-center fw-bold" value="{{config.value}}"
                                    min="0" max="100" step="1" required>
                            </div>
                            <div class="form-text mt-3 text-center bg-light p-2 rounded border">
                                <i class="bi bi-info-circle me-1"></i> Todos los campos son requeridos.
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-2 mt-4">
                            <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow">
                                Guardar Cambios
                            </button>
                            <a href="/admin/config" class="btn btn-outline-secondary rounded-pill">
                                <i class="bi bi-arrow-left me-1"></i> Volver atrás
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>