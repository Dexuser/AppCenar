<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Mis pedidos</h3>
    <span class="badge bg-light text-dark border">{{orders.length}} Total</span>
  </div>

  <div class="row">
    {{#if hasOrders}}
    {{#each orders}}
    <div class="col-12 mb-3">
      <a href="/delivery/order/{{this._id}}" class="text-decoration-none text-dark">
        <div class="card border-0 shadow-sm p-3 rounded-4 hover-shadow transition">
          <div class="d-flex align-items-center">
            <img src="{{this.commerce.logo}}" class="rounded-circle border me-3"
              style="width: 55px; height: 55px; object-fit: cover;">

            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <span
                  class="badge rounded-pill text-uppercase px-3 py-2 
                                        {{#if (Equals this.status 'pending')}}bg-warning-subtle text-warning-emphasis{{/if}}
                                        {{#if (Equals this.status 'in_progress')}}bg-primary-subtle text-primary-emphasis{{/if}}
                                        {{#if (Equals this.status 'completed')}}bg-success-subtle text-success-emphasis{{/if}}">
                  ● {{this.status}}
                </span>
                <small class="text-muted fw-medium">{{this.dateDisplay}} • {{this.timeDisplay}}</small>
              </div>

              <h5 class="fw-bold mt-2 mb-1">{{this.commerceDisplayName}}</h5>

              <div class="d-flex justify-content-between align-items-center mt-2">
                <span class="fw-bold fs-5 text-dark">RD$ {{this.total}}</span>
                <span class="text-muted small">
                  <i class="bi bi-box-seam me-1"></i>{{this.productCount}} productos
                </span>
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
    {{/each}}
    {{else}}
    <div class="col-12 text-center py-5">
      <i class="bi bi-inbox text-muted display-1"></i>
      <p class="text-muted mt-3 fs-5">Aún no has recibido pedidos.</p>
    </div>
    {{/if}}
  </div>
</div>
