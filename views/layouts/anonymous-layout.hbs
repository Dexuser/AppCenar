<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/css/lib/bootstrap/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />

  <link rel="stylesheet" href="/assets/css/site/main.css" />

  {{{_sections.styles}}}
  <title>{{pageTitle}} | AppCenar</title>
</head>

<body>

  <header class="sticky-top shadow-sm">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary-gradient">
      <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
          <i class="bi bi-egg-fried me-2 fs-3"></i>
          <span>AppCenar</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item">
              <a class="nav-link active fw-semibold" href="/">
                <i class="bi bi-box-arrow-in-right me-1"></i> Login
              </a>
            </li>
            <li class="nav-item ms-lg-3">
              <a class="btn btn-light rounded-pill px-4 fw-bold text-primary shadow-sm" href="/user/register-select">
                Comenzar <i class="bi bi-arrow-right ms-1"></i>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <main class="content-wrapper container my-5">

    {{!-- Sistema de Alertas mejorado --}}
    <div class="row justify-content-center">
      <div class="col-md-8">
        {{#if hasErrors}}
        <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show rounded-4" role="alert">
          <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
            <ul class="mb-0 list-unstyled">
              {{#each errors}}
              <li><strong>Error:</strong> {{this}}</li>
              {{/each}}
            </ul>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
        </div>
        {{/if}}

        {{#if hasSuccess}}
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show rounded-4" role="alert">
          <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <ul class="mb-0 list-unstyled">
              {{#each success}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
        </div>
        {{/if}}
      </div>
    </div>

    {{{body}}}
  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="/assets/js/lib/bootstrap/bootstrap.min.js"></script>
  {{{_sections.scripts}}}
</body>

</html>