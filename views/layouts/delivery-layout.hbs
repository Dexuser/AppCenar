<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}} | AppCenar Delivery</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/css/lib/bootstrap/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

  <link rel="stylesheet" href="/assets/css/site/main.css" />
  <link rel="stylesheet" href="/assets/css/site/commerce.css" />

</head>

<body>

  <header class="sticky-top">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" href="/delivery">
          <div class="bg-warning text-dark rounded-3 px-2 py-1">
            <i class="bi bi-egg-fried"></i>
          </div>
          <span>AppCenar <span class="text-warning text-uppercase fs-6 ls-1">Delivery</span></span>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav mx-auto">
            <li class="nav-item">
              <a class="nav-link px-3" href="/delivery">
                <i class="bi bi-speedometer2 me-1"></i> Pedidos
              </a>
            </li>
          </ul>

          <div class="d-flex align-items-center gap-3">
            <a href="/delivery/profile"
              class="text-decoration-none user-pill d-flex align-items-center py-1 ps-1 pe-3 rounded-pill text-white">
              {{#if user.profilePicture}}
              <img src="{{user.profilePicture}}" width="32" height="32"
                class="rounded-circle me-2 border border-2 border-warning" style="object-fit: cover;">
              {{else}}
              <div class="bg-secondary rounded-circle me-2 d-flex align-items-center justify-content-center"
                style="width:32px; height:32px">
                <i class="bi bi-shop text-white small"></i>
              </div>
              {{/if}}
              <div class="d-none d-sm-block">
                <p class="mb-0 small lh-1 fw-bold">{{user.firstName}} {{user.lastName}}</p>
                <small class="text-warning" style="font-size: 0.7rem;">Gestionar Perfil</small>
              </div>
            </a>

            <div class="vr text-white opacity-25 d-none d-lg-block"></div>

            <a class="btn btn-link text-danger text-decoration-none p-0" href="/user/logout" title="Salir">
              <i class="bi bi-power fs-5"></i>
            </a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main class="container py-5 main-content">
    {{!-- Alertas unificadas con diseño más limpio --}}
    {{#if hasErrors}}
    <div
      class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4 border-start border-danger border-4"
      role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-x-circle-fill fs-4 me-3"></i>
        <div class="fw-medium">
          {{#each errors}}
          <div>{{this}}</div>
          {{/each}}
        </div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {{/if}}

    {{#if hasSuccess}}
    <div
      class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4 border-start border-success border-4"
      role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-check-all fs-3 me-3"></i>
        <div class="fw-medium">
          {{#each success}}
          <div>{{this}}</div>
          {{/each}}
        </div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {{/if}}

    {{{body}}}
  </main>

  <footer class="bg-white py-5 border-top mt-auto">
    <div class="container text-center text-muted">
      <p class="mb-1 fw-bold">AppCenar Delivery Portal</p>
      <small>&copy; 2026 Todos los derechos reservados.</small>
      <div class="mt-2 d-flex justify-content-center gap-3">
        <a href="#" class="text-muted small text-decoration-none">Soporte</a>
        <a href="#" class="text-muted small text-decoration-none">Términos</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="/assets/js/lib/bootstrap/bootstrap.min.js"></script>

  {{{_sections.scripts}}}
</body>

</html>